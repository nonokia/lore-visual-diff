# Path to the `lore` executable. Defaults to "lore" (resolved via PATH).
LORE_BIN_PATH=lore

# Absolute path to a `lore clone --bare` checkout. Required.
LORE_REPO_PATH=/path/to/bare-clone

# Comma-separated, repo-relative paths of image files to browse/diff.
# See design doc §2/§8 — Lore has no verified "list files" primitive yet,
# so the MVP file browser is this configured allowlist.
LORE_WATCHED_PATHS=assets/hero.png,assets/logo.png

# Where extracted `lore file write` output and the diff cache live.
# Defaults shown below (relative to the process cwd).
LORE_EXTRACT_DIR=.cache/extracted
LORE_DIFF_CACHE_DIR=.cache/diffs
